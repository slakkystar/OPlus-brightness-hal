// OPlus Brightness Adaptor for Transsion (OS15+ only)
// Standalone vendor userspace daemon — not a HIDL/AIDL Binder HAL.

cc_binary {
    name: "vendor.oplus.brightness.adaptor",
    vendor: true,
    relative_install_path: "hw",

    srcs: ["display_service.c"],

    shared_libs: [
        "liblog",
        "libc",
        "libm",
    ],

    cflags: [
        "-Wall",
        "-Wextra",
        "-Werror",
        "-O2",
    ],

    init_rc: ["init.oplus.brightness.adaptor.rc"],
}
